{
	"schemaVersion": 1,
	"id": "flectonepulse",
	"version": "${version}",
	"name": "FlectonePulse",
	"description": "${description}",
	"authors": [
		"TheFaser"
	],
	"contact": {
		"homepage": "https://flectone.net/pulse/",
		"sources": "https://github.com/Flectone/FlectonePulse/"
	},
	"license": "GPL-3.0",
	"icon": "assets/flectonepulse/icon.png",
    "environment": "server",
