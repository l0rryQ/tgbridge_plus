			"net.flectone.pulse.module.integration.simplevoice.MinecraftSimpleVoiceIntegration"
        ]
	},
	"mixins": [
		"flectonepulse.mixins.json"
	],
	"depends": {
      "fabricloader": "*",
      "fabric-api-base": "*",
      "minecraft": ">=26.1",
      "java": ">=25",
